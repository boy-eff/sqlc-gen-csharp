<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <RootNamespace>SqlcGenCsharp</RootNamespace>
        <OutputType>Exe</OutputType>
        <RuntimeIdentifier>wasi-wasm</RuntimeIdentifier>

        <!-- Критично для стабильности sqlc WASM-плагинов -->
        <PublishTrimmed>false</PublishTrimmed>
        <WasmSingleFileBundle>true</WasmSingleFileBundle>

        <!-- Полезные отключения (можно оставить) -->
        <EventSourceSupport>false</EventSourceSupport>
        <UseSystemResourceKeys>true</UseSystemResourceKeys>
        <EnableUnsafeUTF7Encoding>false</EnableUnsafeUTF7Encoding>
        <DebuggerSupport>false</DebuggerSupport>

        <!-- Дополнительно помогает в некоторых случаях -->
        <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
        <OptimizationPreference>Size</OptimizationPreference>

        <Optimize>false</Optimize>
        <DebugType>embedded</DebugType>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\SqlcGenCsharp\SqlcGenCsharp.csproj"/>
    </ItemGroup>
    
</Project>
